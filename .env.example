# ==============================================================================
# Sufrah Theme - Environment Variables Example
# ==============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ------------------------------------------------------------------------------
# Salla Configuration
# ------------------------------------------------------------------------------

# Your Salla Store URL (without https://)
SALLA_STORE_URL=your-store.salla.sa

# Salla App Credentials (Get from Salla Partners Dashboard)
SALLA_APP_ID=
SALLA_APP_SECRET=
SALLA_MERCHANT_ID=

# Salla Webhook Secret (for verifying webhook requests)
SALLA_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Development Settings
# ------------------------------------------------------------------------------

# Environment mode (development | production | staging)
NODE_ENV=development

# Enable/disable source maps for debugging
GENERATE_SOURCEMAP=true

# Webpack Dev Server Port
DEV_SERVER_PORT=3000

# Enable Hot Module Replacement
HMR_ENABLED=true

# ------------------------------------------------------------------------------
# Theme Configuration
# ------------------------------------------------------------------------------

# Theme version (matches package.json version)
THEME_VERSION=1.0.0

# Enable debug mode (shows additional logs and warnings)
DEBUG_MODE=true

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=false

# ------------------------------------------------------------------------------
# Restaurant-Specific Settings
# ------------------------------------------------------------------------------

# Default restaurant timezone (IANA timezone identifier)
RESTAURANT_TIMEZONE=Asia/Riyadh

# Default currency code
CURRENCY_CODE=SAR

# Enable advanced restaurant features
ENABLE_MODIFIERS=true
ENABLE_DELIVERY_ZONES=true
ENABLE_SCHEDULING=true
ENABLE_BUSINESS_HOURS=true

# ------------------------------------------------------------------------------
# Third-Party Integrations
# ------------------------------------------------------------------------------

# Google Maps API Key (for delivery zones map)
GOOGLE_MAPS_API_KEY=

# Google Analytics Tracking ID
GA_TRACKING_ID=

# Facebook Pixel ID
FACEBOOK_PIXEL_ID=

# WhatsApp Business Number (with country code, no +)
WHATSAPP_NUMBER=

# ------------------------------------------------------------------------------
# Performance & Optimization
# ------------------------------------------------------------------------------

# Enable lazy loading for images
LAZY_LOAD_IMAGES=true

# Cache TTL in seconds (default: 5 minutes)
CACHE_TTL=300

# Minify assets in production
MINIFY_ASSETS=true

# Preload critical fonts
PRELOAD_CRITICAL_FONTS=true

# ------------------------------------------------------------------------------
# API Settings
# ------------------------------------------------------------------------------

# API Base URL (usually your Salla store API)
API_BASE_URL=https://api.salla.sa/admin/v2

# API Request Timeout (milliseconds)
API_TIMEOUT=10000

# API Rate Limiting (requests per minute)
API_RATE_LIMIT=60

# ------------------------------------------------------------------------------
# Localization
# ------------------------------------------------------------------------------

# Default language (ar | en)
DEFAULT_LANGUAGE=ar

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=ar,en

# Enable RTL support
RTL_ENABLED=true

# ------------------------------------------------------------------------------
# Build Settings
# ------------------------------------------------------------------------------

# Public path for assets (usually /public/)
PUBLIC_PATH=/public/

# Asset URL prefix (CDN URL if using one)
ASSET_URL_PREFIX=

# Enable CSS extraction
EXTRACT_CSS=true

# Enable CSS purging in production
PURGE_CSS=true

# ------------------------------------------------------------------------------
# Testing & Quality Assurance
# ------------------------------------------------------------------------------

# Enable test mode (disables real API calls)
TEST_MODE=false

# Mock API responses in development
MOCK_API_RESPONSES=false

# Enable accessibility testing
A11Y_TESTING=false

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------

# Enable Content Security Policy
ENABLE_CSP=false

# Allowed domains for CSP (comma-separated)
CSP_ALLOWED_DOMAINS=*.salla.sa,*.google.com

# Enable HTTPS-only cookies
SECURE_COOKIES=false

# ------------------------------------------------------------------------------
# Logging & Monitoring
# ------------------------------------------------------------------------------

# Log level (debug | info | warn | error)
LOG_LEVEL=debug

# Enable error reporting to external service
ENABLE_ERROR_REPORTING=false

# Error reporting service URL
ERROR_REPORTING_URL=

# Enable analytics for theme usage
ENABLE_USAGE_ANALYTICS=false

# ------------------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------------------

# Enable dark mode feature
FEATURE_DARK_MODE=false

# Enable product comparison
FEATURE_PRODUCT_COMPARE=false

# Enable newsletter popup
FEATURE_NEWSLETTER_POPUP=false

# Enable social sharing
FEATURE_SOCIAL_SHARING=true

# Enable product reviews
FEATURE_PRODUCT_REVIEWS=true

# Enable wishlist
FEATURE_WISHLIST=true

# ------------------------------------------------------------------------------
# Restaurant Feature Flags
# ------------------------------------------------------------------------------

# Enable calories display in menu
FEATURE_SHOW_CALORIES=true

# Enable preparation time display
FEATURE_SHOW_PREP_TIME=true

# Enable allergens information
FEATURE_SHOW_ALLERGENS=true

# Enable ingredients list
FEATURE_SHOW_INGREDIENTS=false

# Enable table reservation (future feature)
FEATURE_TABLE_RESERVATION=false

# Enable loyalty program integration
FEATURE_LOYALTY_PROGRAM=false

# ------------------------------------------------------------------------------
# Development Tools
# ------------------------------------------------------------------------------

# Enable Webpack Bundle Analyzer
ANALYZE_BUNDLE=false

# Enable CSS stats report
CSS_STATS=false

# Enable verbose webpack output
WEBPACK_VERBOSE=false

# Enable automatic browser opening on dev server start
AUTO_OPEN_BROWSER=true
