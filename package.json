{
  "name": "sufrah-salla-theme",
  "version": "1.0.0",
  "description": "أول قالب متخصص للمطاعم والمطابخ السحابية على منصة سلة - First specialized restaurant theme for Salla platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Diaa1123/Sufrah_f.git"
  },
  "keywords": [
    "salla",
    "theme",
    "restaurant",
    "food",
    "delivery",
    "cloud-kitchen",
    "مطعم",
    "سلة",
    "توصيل",
    "مطبخ-سحابي"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "webpack --mode development --watch",
    "watch": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "production": "webpack --mode production",
    "prod": "webpack --mode production",
    "development": "webpack --mode development",
    "clean": "rm -rf public/*",
    "rebuild": "pnpm run clean && pnpm run build",
    "serve": "node dev-server.js",
    "dev:server": "concurrently \"pnpm run dev\" \"pnpm run serve\"",
    "start": "pnpm run build && pnpm run serve",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "lint:js": "eslint \"src/assets/js/**/*.js\" --max-warnings=0",
    "lint:js:fix": "eslint \"src/assets/js/**/*.js\" --fix",
    "lint:css": "stylelint \"src/assets/styles/**/*.scss\"",
    "lint:css:fix": "stylelint \"src/assets/styles/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{js,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,scss,json,md}\"",
    "validate": "pnpm run format:check && pnpm run lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "analyze": "webpack --mode production --profile --json > stats.json && webpack-bundle-analyzer stats.json public"
  },
  "author": "Diaa",
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "animejs": "^3.2.1",
    "fslightbox": "^3.7.3",
    "lite-youtube-embed": "^0.2.0",
    "mmenu-light": "^3.0.9",
    "sweetalert2": "^11.26.17"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@jest/globals": "^30.3.0",
    "@salla.sa/twilight": "^2.14.374",
    "@salla.sa/twilight-components": "^2.14.374",
    "@salla.sa/twilight-tailwind-theme": "^2.14.374",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/line-clamp": "^0.4.0",
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@testing-library/jest-dom": "^6.9.1",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.0.0",
    "babel-loader-exclude-node-modules-except": "^1.2.1",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.5.0",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "eslint": "^8.57.0",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mini-css-extract-plugin": "^2.9.4",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^8.0.1",
    "prettier": "^3.2.5",
    "sass": "^1.97.2",
    "sass-loader": "^16.0.6",
    "stylelint": "^16.2.1",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-scss": "^6.1.0",
    "tailwindcss": "^3.4.19",
    "terser-webpack-plugin": "^5.4.0",
    "webpack": "^5.103.0",
    "webpack-cli": "^5.0.1"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.17.23"
    }
  }
}
