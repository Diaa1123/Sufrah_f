{#
  Delivery Zone Selector Component
  Shows in cart/checkout pages

  Usage:
  {% include 'components/restaurant/delivery-zone-selector.twig' with {
    show_map: false,
    compact: false
  } %}
#}

{% set zones = salla.config.get('delivery_zones', []) %}
{% set show_map = show_map|default(false) %}
{% set compact = compact|default(false) %}

<div class="delivery-zones-widget bg-white rounded-xl border-2 border-gray-200 overflow-hidden"
     data-delivery-zones>

  {# Header #}
  <div class="p-4 bg-gradient-to-r from-primary-50 to-secondary-50 border-b-2 border-gray-200">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center flex-shrink-0">
        <i class="sicon-truck text-white text-xl"></i>
      </div>
      <div class="flex-1">
        <h3 class="text-lg font-bold text-gray-900">
          {{ 'restaurant.delivery_zone'|t }}
        </h3>
        <p class="text-sm text-gray-600">
          {{ 'restaurant.select_zone_desc'|t }}
        </p>
      </div>
    </div>
  </div>

  {# Zone Selector #}
  <div class="p-4">
    <label class="block text-sm font-semibold text-gray-700 mb-2">
      {{ 'restaurant.select_zone'|t }}
      <span class="text-accent-500">*</span>
    </label>

    <select
      data-zone-selector
      required
      class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg
             focus:ring-2 focus:ring-primary-500 focus:border-primary-500
             transition-all duration-200
             bg-white text-gray-900 font-medium
             cursor-pointer"
    >
      <option value="">{{ 'restaurant.select_zone'|t }}</option>
      {% for zone in zones %}
        {% if zone.enabled|default(true) %}
          <option
            value="{{ zone.id }}"
            data-price="{{ zone.price }}"
            data-min="{{ zone.min_order }}"
            data-time="{{ zone.estimated_time }}"
          >
            {{ zone.name }} - {{ zone.price }} {{ 'common.currency'|t }}
          </option>
        {% endif %}
      {% endfor %}
    </select>
  </div>

  {# Zone Details (shown when zone selected) #}
  <div class="zone-details hidden p-4 pt-0" data-zone-details>
    <div class="grid grid-cols-3 gap-4 p-4 bg-gray-50 rounded-lg">
      <div class="text-center">
        <div class="text-xs text-gray-500 mb-1">
          {{ 'restaurant.delivery_fee'|t }}
        </div>
        <div class="text-lg font-bold text-primary-600" data-delivery-fee>
          -
        </div>
      </div>

      <div class="text-center border-x border-gray-200">
        <div class="text-xs text-gray-500 mb-1">
          {{ 'restaurant.min_order'|t }}
        </div>
        <div class="text-lg font-bold text-gray-900" data-min-order>
          -
        </div>
      </div>

      <div class="text-center">
        <div class="text-xs text-gray-500 mb-1">
          {{ 'restaurant.estimated_time'|t }}
        </div>
        <div class="text-lg font-bold text-secondary-600" data-delivery-time>
          -
        </div>
      </div>
    </div>

    {# Zone Coverage Info (optional) #}
    <div class="mt-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-sm">
      <div class="flex items-start gap-2">
        <i class="sicon-info-circle text-blue-600 flex-shrink-0 mt-0.5"></i>
        <p class="text-blue-800">
          {{ 'restaurant.zone_coverage_info'|t }}
        </p>
      </div>
    </div>
  </div>

  {# Warning Message (shown when validation fails) #}
  <div class="hidden p-4 pt-0" data-zone-warning>
    <div class="p-4 bg-amber-50 border-2 border-amber-200 rounded-lg">
      {# Content will be injected by JS #}
    </div>
  </div>

  {# Map (optional) #}
  {% if show_map %}
    <div class="zone-map hidden p-4 pt-0" data-zone-map>
      <div class="h-64 bg-gray-100 rounded-lg overflow-hidden">
        {# Map will be rendered here by JS #}
        <div class="flex items-center justify-center h-full text-gray-400">
          <i class="sicon-map text-4xl"></i>
        </div>
      </div>
    </div>
  {% endif %}
</div>
