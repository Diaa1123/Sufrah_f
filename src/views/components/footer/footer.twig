<footer class="store-footer restaurant-footer bg-gray-900 text-gray-300">
  {# Main Footer Content #}
  <div aria-label="footer" class="store-footer__inner py-12 md:py-16">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-6">

        {# Restaurant Info Section (Wider on Desktop) #}
        <div class="lg:col-span-4">
          <a href="{{ link('/') }}" class="inline-block mb-4">
            {% if store.logo %}
              <img src="{{ store.logo|cdn(150) }}"
                   alt="{{ store.name }}"
                   class="h-12 md:h-14 w-auto brightness-0 invert"
                   loading="lazy">
            {% else %}
              <h3 class="text-2xl font-bold text-white">{{ store.name }}</h3>
            {% endif %}
          </a>

          {% if store.description %}
            <div class="text-sm leading-6 mb-6 max-w-sm text-gray-400">
              {{ store.description|raw }}
            </div>
          {% endif %}

          {# Business hours - uses theme settings #}
          <div class="mb-6 bg-gray-800 rounded-xl p-4">
            <h4 class="text-white font-semibold mb-3 flex items-center gap-2">
              <i class="sicon-clock"></i>
              {{ trans('common.working_hours') }}
            </h4>
            <p class="text-sm text-gray-400">{{ trans('common.contact_us_for_hours') }}</p>
          </div>

          {# Social Media (Desktop) #}
          <div class="hidden lg:block">
            <h4 class="text-white font-semibold mb-3">{{ trans('common.follow_us') }}</h4>
            <salla-social dark class="block mb-6"></salla-social>
          </div>
        </div>

        {# Quick Links Section #}
        <div class="lg:col-span-2">
          <h3 class="text-white font-bold text-lg mb-4">{{ trans('blocks.footer.pages_links') }}</h3>
          <salla-menu source="footer" class="footer-menu"></salla-menu>

          {# Additional Restaurant Links #}
          <div class="mt-4 space-y-2">
            <a href="{{ link('products') }}"
               class="block text-sm hover:text-white transition-colors">
              <i class="sicon-dining {{ theme.is_rtl ? 'ml-1' : 'mr-1' }}"></i>
              {{ trans('restaurant.menu') }}
            </a>
          </div>
        </div>

        {# Contact Information Section #}
        <div class="lg:col-span-3">
          <h3 class="text-white font-bold text-lg mb-4">{{ trans('common.contact_us') }}</h3>

          <div class="space-y-3">
            {# Phone #}
            {% if store.contacts.mobile %}
              <a href="tel:{{ store.contacts.mobile }}"
                 class="flex items-start gap-3 text-sm hover:text-white transition-colors group">
                <i class="sicon-phone text-xl text-primary-400 group-hover:text-primary-300 mt-0.5"></i>
                <div>
                  <div class="font-medium text-white">{{ trans('common.phone') }}</div>
                  <div class="unicode">{{ store.contacts.mobile }}</div>
                </div>
              </a>
            {% endif %}

            {# WhatsApp #}
            {% if store.contacts.whatsapp %}
              <a href="https://wa.me/{{ store.contacts.whatsapp|replace({' ': '', '+': '', '-': ''}) }}"
                 class="flex items-start gap-3 text-sm hover:text-white transition-colors group"
                 target="_blank"
                 rel="noopener">
                <i class="sicon-whatsapp text-xl text-green-400 group-hover:text-green-300 mt-0.5"></i>
                <div>
                  <div class="font-medium text-white">{{ trans('common.whatsapp') }}</div>
                  <div class="unicode">{{ store.contacts.whatsapp }}</div>
                </div>
              </a>
            {% endif %}

            {# Email #}
            {% if store.contacts.email %}
              <a href="mailto:{{ store.contacts.email }}"
                 class="flex items-start gap-3 text-sm hover:text-white transition-colors group">
                <i class="sicon-envelope text-xl text-accent-400 group-hover:text-accent-300 mt-0.5"></i>
                <div>
                  <div class="font-medium text-white">{{ trans('common.email') }}</div>
                  <div class="break-all">{{ store.contacts.email }}</div>
                </div>
              </a>
            {% endif %}

            {# Address (if available) #}
            {% if store.contacts.address %}
              <div class="flex items-start gap-3 text-sm">
                <i class="sicon-location text-xl text-primary-400 mt-0.5"></i>
                <div>
                  <div class="font-medium text-white">{{ trans('common.address') }}</div>
                  <div>{{ store.contacts.address }}</div>
                </div>
              </div>
            {% endif %}
          </div>

          {# Social Media (Mobile/Tablet) #}
          <div class="lg:hidden mt-6">
            <h4 class="text-white font-semibold mb-3">{{ trans('common.follow_us') }}</h4>
            <salla-social dark></salla-social>
          </div>
        </div>

        {# Mobile Apps Section #}
        <div class="lg:col-span-3">
          <h3 class="text-white font-bold text-lg mb-4">{{ trans('common.download_app') }}</h3>
          <salla-apps-icons dark></salla-apps-icons>

          {# Newsletter Subscription (Optional) #}
          {% if theme.settings.get('newsletter_enabled') %}
            <div class="mt-6">
              <h4 class="text-white font-semibold mb-3">{{ trans('common.newsletter') }}</h4>
              <form onsubmit="return subscribeNewsletter(event)" class="flex gap-2">
                <input type="email"
                       name="email"
                       placeholder="{{ trans('common.email_placeholder') }}"
                       required
                       class="form-input flex-1 bg-gray-800 border-gray-700 text-white placeholder-gray-500 rounded-lg">
                <salla-button type="submit" color="primary">
                  {{ trans('common.subscribe') }}
                </salla-button>
              </form>
            </div>
          {% endif %}
        </div>

      </div>
    </div>
  </div>

  {# Trust Badges & Tax Info #}
  <div class="border-t border-gray-800 py-6">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        {# Trust Badges #}
        <div class="flex items-center gap-4">
          <salla-trust-badges dark></salla-trust-badges>

          {# VAT Number #}
          {% if store.settings.tax.number %}
            <div class="flex items-center gap-3">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick cursor-pointer"
                   data-modal-id="modal-value-tax"
                   href="#/"
                   aria-label="{{ store.settings.tax.number }}">
                  <img width="40"
                       height="50"
                       src="{{ 'images/tax.png'|cdn(70, 70) }}"
                       loading="lazy"
                       class="w-10 rounded-sm hover:opacity-80 transition-opacity"
                       alt="value added tax">
                </a>
              {% endif %}
              <div>
                <p class="text-xs text-gray-500 mb-1">{{ trans('common.elements.tax_number') }}</p>
                <b class="text-sm text-white">{{ store.settings.tax.number }}</b>
              </div>
            </div>

            {# Tax Certificate Modal #}
            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first
                           sub-title="{{ trans('common.elements.tax_number') }}"
                           modal-title="{{ store.settings.tax.number }}"
                           id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full"
                       loading="lazy"
                       src="{{ store.settings.tax.certificate }}"
                       alt="{{ store.settings.tax.number }}"/>
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>

        {# Payment Methods #}
        <div>
          <salla-payments dark></salla-payments>
        </div>
      </div>
    </div>
  </div>

  {# Copyright & Credits #}
  <div class="border-t border-gray-800 py-4">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        {# Copyright #}
        <div class="text-center md:text-{{ theme.is_rtl ? 'right' : 'left' }}">
          {% hook copyright %}
          <span class="copyright-text">
            © {{ "now"|date("Y") }} {{ store.name }}. {{ trans('common.all_rights_reserved') }}
          </span>
        </div>

        {# Powered by Salla #}
        <div class="flex items-center gap-2 text-gray-500">
          <span>{{ trans('common.powered_by') }}</span>
          <a href="https://salla.sa"
             target="_blank"
             rel="noopener"
             class="text-primary-400 hover:text-primary-300 transition-colors font-semibold">
            Salla
          </a>
        </div>
      </div>
    </div>
  </div>

  {# Delivery Zones Info Banner (Optional) #}
  {% if theme.settings.get('restaurant.show_delivery_banner') %}
    <div class="bg-primary-900 py-4">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-center gap-3 text-sm text-white">
          <i class="sicon-truck-fast text-xl"></i>
          <span>{{ trans('restaurant.delivery_banner_text') }}</span>
        </div>
      </div>
    </div>
  {% endif %}
</footer>

{# Back to Top Button #}
<button id="backToTop"
        class="back-to-top-btn fixed bottom-6 {{ theme.is_rtl ? 'left-6' : 'right-6' }} bg-primary-600 hover:bg-primary-700 text-white w-12 h-12 rounded-full shadow-lg flex items-center justify-center opacity-0 invisible transition-all duration-300 z-40"
        aria-label="{{ trans('common.back_to_top') }}"
        onclick="scrollToTop()">
  <i class="sicon-keyboard_arrow_up text-2xl"></i>
</button>

{# Footer JavaScript #}
<script>
// Back to top button
function scrollToTop() {
  window.scrollTo({
    top: 0,
    behavior: 'smooth'
  });
}

// Show/hide back to top button
window.addEventListener('scroll', () => {
  const backToTop = document.getElementById('backToTop');
  if (window.pageYOffset > 300) {
    backToTop.classList.remove('opacity-0', 'invisible');
    backToTop.classList.add('opacity-100', 'visible');
  } else {
    backToTop.classList.add('opacity-0', 'invisible');
    backToTop.classList.remove('opacity-100', 'visible');
  }
});

// Newsletter subscription (if enabled)
{% if theme.settings.get('newsletter_enabled') %}
function subscribeNewsletter(event) {
  event.preventDefault();
  const form = event.target;
  const email = form.email.value;

  // Use Salla newsletter API or custom implementation
  fetch('/api/newsletter/subscribe', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({ email })
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      salla.notify.success('{{ trans('common.newsletter_success') }}');
      form.reset();
    } else {
      salla.notify.error(data.message || '{{ trans('common.newsletter_error') }}');
    }
  })
  .catch(error => {
    salla.notify.error('{{ trans('common.newsletter_error') }}');
  });

  return false;
}
{% endif %}
</script>

{# Hidden utility classes for Tailwind purge #}
<span class="hidden bottom-2 {{ theme.is_rtl ? 'pl-24' : 'pr-24' }} md:grid-cols-3 opacity-40"></span>
