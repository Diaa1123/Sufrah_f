{% extends "layouts/master.twig" %}

{% block content %}

<div class="cart-page bg-gray-50 min-h-screen py-8">
  <div class="container mx-auto px-4">

    {# Breadcrumb #}
    <nav class="mb-6">
      <salla-breadcrumb></salla-breadcrumb>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-8">
      {{ 'blocks.header.cart'|t }}
    </h1>

    {# Conditional Offer Banner #}
    <salla-conditional-offer></salla-conditional-offer>

    {% if cart.items and cart.items|length > 0 %}

      <div class="grid lg:grid-cols-3 gap-8">

        {# === CART ITEMS (Left Side) === #}
        <div class="lg:col-span-2 space-y-4">
          {% hook 'cart:items.start' %}

          {% for item in cart.items %}
            <form onchange="salla.form.onChange('cart.updateItem', event)" id="item-{{ item.id }}">
              <div class="cart-item bg-white rounded-xl p-6 shadow-sm relative">
                <input type="hidden" name="id" value="{{ item.id }}">

                {# Free Product Ribbon #}
                {% if item.price.getMoney().amount == 0 and item.has_discount %}
                  <div class="free-ribbon absolute top-3 right-3 bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg z-10">
                    {{ 'pages.loyalty_program.free_product'|t }}
                  </div>
                {% endif %}

                <div class="flex gap-6">
                  {# Product Image #}
                  <a href="{{ item.url }}" class="relative overflow-hidden w-24 h-24 flex-shrink-0 rounded-lg bg-gray-100">
                    <img
                      src="{{ item.product_image }}"
                      alt="{{ item.product_name }}"
                      {% if loop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
                      class="w-full h-full object-cover">
                  </a>

                  {# Product Info #}
                  <div class="flex-1 min-w-0">
                    <h3 class="font-bold text-lg text-gray-900 mb-2">
                      <a href="{{ item.url }}">{{ item.product_name }}</a>
                    </h3>

                    {# Price Display #}
                    <div class="flex items-center gap-2 mb-3 flex-wrap">
                      {% if item.offer %}
                        <span class="text-sm text-gray-400 line-through">{{ item.product_price|money }}</span>
                      {% endif %}
                      {% if item.is_on_sale %}
                        <span class="text-sm text-gray-400 line-through">{{ item.original_price|money }}</span>
                      {% endif %}
                      <span class="font-bold {{ item.has_discount ? 'text-accent-600 text-lg' : 'text-gray-700' }}">
                        {{ item.price|money }}
                      </span>
                    </div>

                    {# Weight #}
                    {% if item.weight_label %}
                      <p class="text-sm text-gray-500 mb-2">
                        {{ 'pages.products.weight'|t }}: <span>{{ item.weight_label }}</span>
                      </p>
                    {% endif %}

                    {# Offers #}
                    {% if item.offer and not item.detailed_offers %}
                      <div class="flex items-center gap-1 text-sm text-gray-600 mb-2">
                        <i class="sicon-discount-calculator"></i>
                        <span>{{ item.offer.names }}</span>
                      </div>
                    {% endif %}

                    {# Detailed Offers #}
                    <salla-cart-item-offers
                      quantity="{{ item.quantity }}"
                      item-id="{{ item.id }}"
                      product-price="{{ item.product_price }}"
                      offers="{{ item.detailed_offers|json_encode }}">
                    </salla-cart-item-offers>

                    {# Quantity & Total #}
                    <div class="flex items-center justify-between mt-4">
                      {# Quantity Input #}
                      <div class="flex items-center gap-3">
                        {% if item.type == 'donating' %}
                          <span></span>
                        {% elseif item.is_hidden_quantity %}
                          <input type="hidden" value="{{ item.quantity }}" name="quantity" aria-label="Quantity"/>
                          <span class="px-4 py-2 border border-gray-300 rounded-lg font-semibold">{{ item.quantity }}</span>
                        {% else %}
                          <salla-quantity-input
                            cart-item-id="{{ item.id }}"
                            max="{{ item.max_quantity }}"
                            value="{{ item.quantity }}"
                            name="quantity"
                            aria-label="Quantity"
                            class="border-gray-200">
                          </salla-quantity-input>
                        {% endif %}
                      </div>

                      {# Item Total #}
                      <div class="text-right">
                        {% set item_total = item.detailed_offers|length > 0 ? item.total_special_price|money : item.total|money %}
                        <div class="text-sm text-gray-600 mb-1">{{ 'pages.cart.total'|t }}:</div>
                        <div class="text-xl font-bold text-primary-600">
                          {{ item.is_available ? item_total : ('pages.cart.out_of_stock'|t) }}
                        </div>
                      </div>
                    </div>
                  </div>

                  {# Remove Button #}
                  <salla-button
                    type="button"
                    shape="icon"
                    size="small"
                    color="danger"
                    class="btn--delete flex-shrink-0"
                    aria-label="Remove from cart"
                    onclick="salla.cart.deleteItem('{{ item.id }}').then(() => document.querySelector('#item-{{ item.id }}').remove())">
                    <i class="sicon-cancel"></i>
                  </salla-button>
                </div>

                {# Product Options #}
                {% include 'pages.partials.product.options' with {product: item} %}
              </div>
            </form>
          {% endfor %}

          {# Cart Options #}
          {% if cart.options|length %}
            <div class="cart-options space-y-4">
              {% for product_option in cart.options %}
                <form
                  class="bg-white rounded-xl p-6 shadow-sm"
                  onchange="salla.form.onChange('cart.updateItem', event)"
                  id="item-{{ product_option.id }}">
                  <input type="hidden" name="id" value="{{ product_option.id }}">
                  <input type="hidden" name="quantity" value="{{ product_option.quantity }}">
                  {% include 'pages.partials.product.options' with {product: product_option} %}
                </form>
              {% endfor %}
            </div>
          {% endif %}

          {# Offers Section #}
          <salla-offer></salla-offer>

          {% hook 'cart:items.end' %}
        </div>

        {# === ORDER SUMMARY (Right Side) === #}
        <div class="space-y-6">
          {% hook 'cart:summary.start' %}

          {# Free Shipping Bar #}
          {% if cart.free_shipping_bar %}
            <div class="bg-white rounded-xl p-6 shadow-sm" id="free-shipping">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <i class="sicon-shipping-fast text-primary-600 text-xl {{ theme.is_rtl ? 'flip-x' : '' }}"></i>
                </div>
                <div class="flex-1">
                  <h4 class="font-bold text-sm mb-1">{{ 'pages.cart.free_shipping'|t }}</h4>
                  <p class="text-sm text-gray-600">
                    {% set is_free = cart.free_shipping_bar.has_free_shipping %}
                    <span id="free-shipping-msg">
                      {{ (is_free ? 'pages.cart.has_free_shipping'|t : ('pages.cart.free_shipping_alert'|t({'amount': cart.free_shipping_bar.remaining|money})))|raw }}
                    </span>
                    <span class="emoji {{ is_free ? '' : 'hidden' }}" id="free-shipping-applied">🎉</span>
                  </p>
                </div>
              </div>
              {% if not is_free %}
                <div class="bg-gray-200 rounded-full h-2.5" id="free-shipping-bar">
                  <div
                    class="bg-primary-600 h-2.5 rounded-full transition-all duration-500 relative"
                    style="width:{{ cart.free_shipping_bar.percent }}%">
                    <i class="sicon-shipping-fast absolute -top-5 {{ theme.is_rtl ? 'left-0 flip-x' : 'right-0' }}"></i>
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}

          {# Loyalty Points #}
          {% if loyalty and user.loyalty_points %}
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <salla-loyalty
                customer-points='{{ user.loyalty_points }}'
                prize-points='{{ loyalty.prize.points }}'
                prize-title='{{ loyalty.prize.title }}'>
              </salla-loyalty>
            </div>
          {% endif %}

          {# Delivery Zone Selector #}
          {% include 'components/restaurant/delivery-zone-selector.twig' %}

          {# Order Scheduling #}
          {% include 'components/restaurant/order-scheduling.twig' %}

          {# Gifting #}
          {% if gift.enabled %}
            <div class="bg-white rounded-xl p-6 shadow-sm" id="cart-gifting">
              <salla-gifting
                widget-title="{{ 'pages.cart.gift_widget_title'|t }}"
                widget-subtitle="{{ gift.text }}"
                {{ gift.type }}-products
                vertical>
              </salla-gifting>
            </div>
          {% endif %}

          {# Order Summary #}
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h2 class="font-bold text-lg mb-6">{{ 'pages.cart.summary'|t }}</h2>

            <div class="space-y-3 mb-6">
              {# Subtotal #}
              <div class="flex items-center justify-between text-gray-700">
                <span>{{ (cart.tax_amount ? 'pages.cart.items_total_without_tax' : 'pages.cart.items_total')|t }}</span>
                <span class="font-semibold" id="sub-total">{{ cart.sub_total|money }}</span>
              </div>

              {# Cart Options Total #}
              {% if cart.options|length %}
                <div class="flex items-center justify-between text-gray-700">
                  <span>{{ 'pages.cart.order_options_total'|t }}</span>
                  <span class="font-semibold" id="cart-options-total">{{ cart.options_total|money }}</span>
                </div>
              {% endif %}

              {# Shipping Cost #}
              <div id="shipping-cost" class="flex items-center justify-between text-gray-700 {{ cart.has_shipping ? '' : 'hidden' }}">
                <span>{{ 'pages.cart.shipping_cost'|t }}</span>
                <span class="font-semibold">{{ cart.real_shipping_cost|money }}</span>
              </div>

              {# Discount #}
              <div id="total-discount" class="flex items-center justify-between text-green-600 {{ cart.total_discount ? '' : 'hidden' }}">
                <span>{{ 'pages.cart.discount'|t }}</span>
                <span class="font-semibold">-{{ cart.total_discount|money }}</span>
              </div>

              {# VAT #}
              {% if cart.tax_amount %}
                <div class="flex items-center justify-between text-gray-700">
                  <span>{{ 'pages.cart.VAT_tax_amount'|t }}</span>
                  <span class="font-semibold" id="tax-amount">{{ cart.tax_amount|money }}</span>
                </div>
              {% endif %}

              {# Total #}
              <div class="border-t border-gray-200 pt-3 flex items-center justify-between text-lg font-bold">
                <span>{{ 'pages.cart.final_total'|t }}</span>
                <span class="text-primary-600" data-cart-total>{{ cart.total|money }}</span>
              </div>
            </div>

            {# Coupon Code #}
            {% if store.settings.cart.apply_coupon_enabled %}
              <div class="border-t border-b border-gray-200 py-6 mb-6">
                <label for="coupon-input" class="block text-sm font-medium mb-2">
                  {{ 'pages.cart.have_coupon'|t }}
                </label>
                <div class="relative">
                  <input
                    type="text"
                    id="coupon-input"
                    name="coupon"
                    placeholder="{{ 'pages.cart.coupon_placeholder'|t }}"
                    {{ cart.coupon ? 'disabled' : '' }}
                    value="{{ cart.coupon }}"
                    aria-label="Apply coupon"
                    class="w-full px-4 py-3 pr-24 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500">
                  <salla-button
                    class="btn--coupon absolute right-2 top-1/2 transform -translate-y-1/2 {{ cart.coupon ? 'has-coupon btn--danger' : 'has-not-coupon btn--default' }}"
                    loader-position="center"
                    id="coupon-btn">
                    <span class="coupon-text">{{ 'pages.cart.save_coupon'|t }}</span>
                    <i class="sicon-cancel icon text-xl w-8"></i>
                  </salla-button>
                </div>
                <span class="text-xs text-red-600 mt-1 block" id="coupon-error"></span>
              </div>
            {% endif %}

            {# Checkout Button #}
            <div class="cart-submit-wrap">
              {% hook 'cart:submit.start' %}
              <salla-button
                id="cart-submit"
                loader-position="center"
                width="wide"
                class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold text-lg py-4 rounded-xl shadow-lg hover:shadow-xl transition-all">
                {{ 'pages.cart.complete_order'|t }}
              </salla-button>
              {% hook 'cart:submit.end' %}
            </div>

            {# Continue Shopping #}
            <a
              href="{{ salla.url.get('products') }}"
              class="block text-center mt-4 text-primary-600 hover:text-primary-700 font-semibold">
              {{ 'cart.continue_shopping'|t }}
            </a>
          </div>

          {# Tiered Offer #}
          <salla-tiered-offer></salla-tiered-offer>

          {% hook 'cart:summary.end' %}
        </div>

      </div>

    {% else %}

      {# Empty Cart #}
      <div class="max-w-md mx-auto text-center py-16">
        <div class="w-32 h-32 mx-auto mb-6 bg-gray-100 rounded-full flex items-center justify-center">
          <i class="sicon-shopping-bag text-gray-400 text-6xl"></i>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">
          {{ 'pages.cart.empty_cart'|t }}
        </h2>
        <p class="text-gray-600 mb-8">
          {{ 'cart.empty_cart_message'|t }}
        </p>
        <a
          href="{{ link('/') }}"
          class="inline-flex items-center gap-3 bg-primary-600 hover:bg-primary-700 text-white font-bold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl transition-all">
          <i class="sicon-book-open text-xl"></i>
          <span>{{ 'common.elements.back_home'|t }}</span>
        </a>
      </div>

    {% endif %}

  </div>
</div>

{% endblock %}

{% block scripts %}
<script defer src="{{ 'checkout.js' | asset }}"></script>

<script>
// Cart page enhancements
document.addEventListener('DOMContentLoaded', () => {
  // Validate delivery zone and scheduling before checkout
  const submitButton = document.getElementById('cart-submit');
  if (submitButton) {
    submitButton.addEventListener('click', (e) => {
      // Check if delivery zones are required
      const deliveryZoneSelector = document.querySelector('[data-delivery-zones]');
      if (deliveryZoneSelector && window.deliveryZones) {
        const validation = window.deliveryZones.validateSelectedZone();
        if (!validation.valid) {
          e.preventDefault();
          salla.notify.warning(validation.message || '{{ "restaurant.errors.select_delivery_zone"|t }}');
          return false;
        }
      }

      // Check if scheduling is required
      const schedulingSelector = document.querySelector('[data-order-scheduling]');
      if (schedulingSelector && window.orderScheduling) {
        const validation = window.orderScheduling.validate();
        if (!validation.valid) {
          e.preventDefault();
          salla.notify.error(validation.errors[0].message);
          return false;
        }
      }
    });
  }

  // Update delivery fee when zone changes
  document.addEventListener('delivery-zone-changed', (event) => {
    const deliveryFeeElement = document.getElementById('delivery-fee');
    if (deliveryFeeElement && event.detail.deliveryFee !== undefined) {
      deliveryFeeElement.textContent = event.detail.deliveryFee > 0
        ? `${event.detail.deliveryFee} {{ 'common.currency'|t }}`
        : '-';
    }
  });

  // Smooth scroll to errors
  const scrollToError = (selector) => {
    const element = document.querySelector(selector);
    if (element) {
      element.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  };

  // Listen for validation errors
  document.addEventListener('validation-error', (event) => {
    if (event.detail.field) {
      scrollToError(`[name="${event.detail.field}"]`);
    }
  });
});
</script>
{% endblock %}
