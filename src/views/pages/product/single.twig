{% extends "layouts/master.twig" %}

{% block content %}

<div class="product-single-page bg-gray-50 py-8">
  <div class="container mx-auto px-4">

    {# Breadcrumb #}
    <nav class="mb-6">
      <salla-breadcrumb></salla-breadcrumb>
    </nav>

    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
      <div class="grid lg:grid-cols-2 gap-8 p-6 lg:p-8">

        {# === LEFT SIDE: IMAGES === #}
        <div class="product-images">
          {# Main Image Gallery using Salla Slider #}
          {% set has_many_images = product.images|length > 1 %}
          <salla-slider
            id="details-slider-{{ product.id }}"
            class="details-slider rounded-2xl overflow-hidden image-slider mb-4"
            type="thumbs"
            loop="false"
            auto-height
            listen-to-thumbnails-option
            show-thumbs-controls="false">

            {# Promotion Title Badge #}
            {% if product.promotion_title %}
              <div class="promotion-title absolute top-4 left-4 z-10 bg-accent-500 text-white px-4 py-2 rounded-lg font-bold shadow-lg">
                {{ product.promotion_title }}
              </div>
            {% endif %}

            {# Wishlist Button #}
            <salla-button
              class="btn--wishlist animated sws absolute top-4 right-4 z-10"
              data-id="{{ product.id }}"
              onclick="salla.wishlist.toggle('{{ product.id }}')"
              shape="icon"
              fill="outline"
              color="light">
              <i class="sicon-heart"></i>
            </salla-button>

            {# Calories Badge #}
            {% if product.calories %}
              <div class="absolute z-10 top-4 left-1/2 transform -translate-x-1/2 bg-white shadow-lg flex flex-col justify-center items-center rounded-full w-20 h-20 md:w-24 md:h-24">
                <span class="text-accent-600 text-xl leading-none font-bold">{{ product.calories }}</span>
                <span class="text-xs text-gray-500">{{ 'common.cal'|t }}</span>
              </div>
            {% endif %}

            {# Main Images #}
            <div slot="items">
              {% for image in product.images %}
                {% if image.three_d_image_url %}
                  <model-viewer
                    style="min-height: 500px;"
                    class="swiper-slide model-entry w-full h-full"
                    loading="eager"
                    camera-controls
                    touch-action="pan-y"
                    auto-rotate
                    poster="{{ image.url }}"
                    src="{{ image.three_d_image_url }}"
                    shadow-intensity="1"
                    alt="{{ image.alt }}">
                  </model-viewer>
                {% else %}
                  <a data-fslightbox="product_{{ product.id }}"
                     data-img-id="{{ image.id }}"
                     data-slid-index="{{ loop.index-1 }}"
                     {% if image.video_url %} data-video-src="{{ image.video_url }}"{% endif %}
                     data-caption="{{ image.alt }}"
                     data-infinite="false"
                     data-type="{{ image.video_url?'youtube':'image' }}"
                     href="{{ (image.video_url is iterable ? image.video_url|first : image.video_url)|default(image.url) }}"
                     aria-label="{{ product.name }}"
                     class="swiper-slide magnify-wrapper {{ image.video_url?'video-entry':'' }}">
                    <img
                      id="{{ image.id }}"
                      {% if loop.first %}fetchpriority="high" loading="eager"{% else %}loading="lazy"{% endif %}
                      src="{{ image.url }}"
                      alt="{{ image.alt }}"
                      class="h-full w-full object-cover {{ image.three_d_image_url ? 'model-poster' : '' }}">
                  </a>
                {% endif %}
              {% endfor %}
            </div>

            {# Thumbnails #}
            {% if has_many_images %}
              <div slot="thumbs">
                {% for image in product.images %}
                  <div class="slide--one-fourth {{ image.video_url?'video-entry':'' }} {{ image.three_d_image_url?'model-entry':'' }}" data-caption="{{ image.alt }}">
                    <img
                      src="{{ image.url }}"
                      {% if loop.index < 5 %}loading="eager"{% else %}loading="lazy"{% endif %}
                      class="object-cover w-full h-full bg-gray-100 rounded-md overflow-hidden"
                      title="{{ image.alt }}"
                      alt="{{ image.alt }}"/>
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </salla-slider>
        </div>

        {# === RIGHT SIDE: INFO & OPTIONS === #}
        <div class="product-info" id="product-{{ product.id }}">

          {% hook 'product:single.description.start' %}

          {# Brand Logo #}
          {% if product.brand.name %}
            <div class="product-brand mb-4 w-12">
              <a class="brand-logo" href="{{ product.brand.url }}" title="{{ product.brand.name }}">
                <img
                  width="100%"
                  height="100%"
                  class="max-h-full object-contain"
                  src="{{ product.brand.logo }}"
                  title="{{ product.brand.name }}"
                  alt="{{ product.brand.name }}">
              </a>
            </div>
          {% endif %}

          {# Product Name #}
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">
            {{ product.name }}
          </h1>

          {# Subtitle #}
          {% if product.subtitle %}
            <h2 class="text-base text-gray-600 mb-3">
              {{ product.subtitle }}
            </h2>
          {% endif %}

          {# Rating #}
          {% if product.rating %}
            <div class="mb-4">
              <salla-rating-stars
                value="{{ product.rating.stars }}"
                reviews="{{ product.rating.count }}">
              </salla-rating-stars>
            </div>
          {% endif %}

          {# Price #}
          <div class="mb-6">
            <div class="flex items-baseline gap-3">
              {% if product.is_on_sale %}
                <span class="text-3xl font-bold text-accent-600">
                  {{ product.sale_price|money }}
                </span>
                <span class="text-xl text-gray-400 line-through">
                  {{ product.regular_price|money }}
                </span>
                {% if product.discount_percentage %}
                  <span class="bg-accent-100 text-accent-700 px-2 py-1 rounded-md text-sm font-semibold">
                    -{{ product.discount_percentage }}
                  </span>
                {% endif %}
              {% else %}
                {% if product.starting_price %}
                  <span class="text-gray-600 text-base">{{ 'products.starting_price'|t }}</span>
                {% endif %}
                <span class="text-3xl font-bold text-primary-600">
                  {{ product.starting_price ? product.starting_price|money : product.price|money }}
                </span>
              {% endif %}
            </div>
            {% if product.is_taxable %}
              <small class="text-gray-500 text-sm">{{ 'products.tax_included'|t }}</small>
            {% endif %}
          </div>

          {# Description #}
          <div class="product__description mb-6 leading-relaxed text-gray-700">
            {% set product_desc = product.description|replace({"&nbsp;":"\n"}) %}
            {% if product.has_read_more %}
              <article
                class="article--main relative overflow-hidden transition-all duration-300"
                id="more-content"
                style="max-height:5.25rem">
                {{ product_desc|raw }}
              </article>
              <a
                id="btn-show-more"
                class="text-primary-600 hover:text-primary-700 font-semibold inline-block mt-2 cursor-pointer">
                {{ 'products.read_more'|t }}
              </a>
            {% else %}
              <article class="article--main">
                {{ product_desc|raw }}
              </article>
            {% endif %}
          </div>

          {# Meta Info Grid #}
          <div class="grid grid-cols-2 gap-3 mb-6">
            {# Calories #}
            {% if product.calories %}
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <i class="sicon-fire text-accent-500 text-lg"></i>
                <span>{{ product.calories }} {{ 'common.cal'|t }}</span>
              </div>
            {% endif %}

            {# Tags #}
            {% if product.tags|length and theme.settings.get('show_tags', true) %}
              <div class="flex flex-wrap gap-2">
                {% for tag in product.tags limit:3 %}
                  <a
                    href="{{ tag.url }}"
                    class="inline-flex items-center px-2 py-1 bg-gray-100 hover:bg-gray-200 rounded-md text-xs text-gray-700 transition-colors">
                    {{ tag.name }}
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </div>

          {# SKU #}
          {% if product.sku %}
            <div class="mb-4 flex items-center gap-2 text-sm text-gray-600">
              <i class="sicon-barcode"></i>
              <span>{{ 'products.sku'|t }}: {{ product.sku }}</span>
            </div>
          {% endif %}

          {# Sold & Stock Info #}
          {% if product.sold_quantity or product.can_show_remained_quantity %}
            <div class="flex gap-4 mb-6 text-sm">
              {% if product.sold_quantity %}
                <div class="flex items-center gap-2 text-accent-600">
                  <i class="sicon-fire"></i>
                  <span>{{ pluralize('products.sold_times', product.sold_quantity)|raw }}</span>
                </div>
              {% endif %}
              {% if product.can_show_remained_quantity %}
                <div class="flex items-center gap-2 text-gray-600">
                  <i class="sicon-box-bankers"></i>
                  <span>{{ 'products.remained'|t }}: {{ product.quantity }}</span>
                </div>
              {% endif %}
            </div>
          {% endif %}

          {# Social Share & Wishlist #}
          <div class="flex items-center gap-3 mb-6">
            <salla-social-share class="inline-flex" aria-label="social share"></salla-social-share>
            <salla-button
              class="btn--wishlist animated hidden sm:inline-flex"
              data-id="{{ product.id }}"
              onclick="salla.wishlist.toggle('{{ product.id }}')"
              shape="icon"
              fill="outline"
              color="light"
              aria-label="add to wishlist">
              <i class="sicon-heart"></i>
            </salla-button>
          </div>

          {% hook 'product:single.description' %}

          {# Installment Methods #}
          <salla-installment price="{{ product.price }}"></salla-installment>

          {# Metadata #}
          {% if product.has_metadata %}
            <salla-metadata></salla-metadata>
          {% endif %}

          {# Availability #}
          {% if product.show_availability %}
            <section class="bg-gray-50 p-4 rounded-lg mb-5">
              <div class="flex items-center justify-between">
                <label class="flex items-center text-base gap-2">
                  <i class="sicon-location"></i>
                  <span>{{ 'products.availability'|t }}</span>
                </label>
                <a
                  href="#!"
                  onclick="salla.event.dispatch('scopes::open', {mode: 'availability', product_id: '{{ product.id }}' })"
                  class="text-primary-600 hover:text-primary-700 flex items-center gap-1">
                  <span>{{ 'products.select_branch'|t }}</span>
                  <i class="sicon-keyboard_arrow_left"></i>
                </a>
              </div>
            </section>
          {% endif %}

          {# Digital Files Settings #}
          {% if product.digital_files_settings %}
            <digital-files-settings settings='{{ product.digital_files_settings|json_encode }}'></digital-files-settings>
          {% endif %}

          {# === PRODUCT FORM === #}
          <form
            class="form product-form"
            enctype="multipart/form-data"
            method="post"
            onsubmit="return salla.form.onSubmit('cart.addItem', event)">
            <input type="hidden" name="id" value="{{ product.id }}">

            {% hook 'product:single.form.start' %}

            {# Product Options (Modifiers) #}
            {% include 'pages.partials.product.options' %}

            {% hook 'product:single.form.end' %}

            {# Price Summary #}
            <section class="bg-gray-50 p-4 rounded-lg mb-4">
              <div class="flex items-center justify-between">
                <label class="font-bold text-lg">
                  {{ 'products.price'|t }}
                </label>
                <div class="price-wrapper">
                  <div class="price_is_on_sale {{ product.is_on_sale ? '' : 'hidden' }}">
                    <h2 class="total-price text-accent-600 font-bold text-2xl inline-block">
                      {{ product.sale_price|money }}
                    </h2>
                    <span class="before-price text-gray-400 line-through ml-2">
                      {{ product.regular_price|money }}
                    </span>
                  </div>
                  <div class="starting-or-normal-price {{ product.is_on_sale ? 'hidden' : 'block' }}">
                    <h2 class="total-price font-bold text-2xl text-primary-600">
                      {{ product.starting_price ? product.starting_price|money : product.price|money }}
                    </h2>
                  </div>
                </div>
                <div class="out-of-stock hidden text-accent-600 font-bold">
                  {{ 'products.out_of_stock'|t }}
                </div>
              </div>
            </section>

            {# Pre-order Campaign #}
            {% if product.has_preorder_campaign %}
              <section class="mb-5">
                <salla-count-down
                  pre-order='{{ product.preorder|json_encode }}'
                  boxed
                  labeled>
                </salla-count-down>
              </section>
            {% endif %}

            {# Quantity & Add to Cart #}
            <section class="sticky-product-bar bg-white border-2 border-gray-200 p-5 rounded-xl">
              {# Quantity #}
              {% if product.is_hidden_quantity or product.type == 'booking' %}
                <input type="hidden" value="1" name="quantity" aria-label="Quantity"/>
              {% else %}
                <div class="flex items-center justify-between mb-5">
                  <label class="font-bold">
                    {{ 'products.quantity'|t }}
                  </label>
                  <salla-quantity-input
                    max="{{ product.max_quantity }}"
                    value="1"
                    name="quantity"
                    aria-label="Quantity"
                    class="border-gray-200">
                  </salla-quantity-input>
                </div>
              {% endif %}

              {# Add to Cart Button #}
              <salla-add-product-button
                {{ product.can_quick_buy ? 'quick-buy' : '' }}
                {{ theme.settings.get('sticky_add_to_cart') ? 'support-sticky-bar' : '' }}
                {{ product.is_require_shipping ? 'required-shipping' : '' }}
                {{ product.has_preorder_campaign ? 'has-pre-order' : '' }}
                amount="{{ product.base_currency_price }}"
                class="w-full"
                product-status="{{ product.status }}"
                product-type="{{ product.type }}"
                product-id="{{ product.id }}"
                loader-position="end"
                type="submit"
                width="wide"
                {% if product.notify_availability %}
                  {{ product.notify_availability.subscribed ? 'is-subscribed' : '' }}
                  channels="{{ product.notify_availability.channels|join(',') }}"
                  subscribed-options="{{ product.notify_availability.subscribed_options|json_encode }}"
                  {{ product.notify_availability.options ? 'notify-options-availability' : '' }}
                {% endif %}>
                {{ product.add_to_cart_label }}
              </salla-add-product-button>
            </section>

            {# Gifting #}
            {% if product.is_giftable %}
              <salla-gifting
                class="mt-5"
                widget-subtitle="{{ gifting_intro }}"
                product-id="{{ product.id }}"
                {{ product.is_require_shipping ? 'physical-products' : '' }}>
              </salla-gifting>
            {% endif %}
          </form>

          {% hook 'product:single.description.end' %}

          {# Quick Order #}
          <salla-quick-order class="mt-5 block"></salla-quick-order>
        </div>
      </div>

      {# === TABS SECTION === #}
      <div class="border-t border-gray-200 p-6 lg:p-8">
        {# Tabs Navigation #}
        <div class="mb-6 border-b border-gray-200">
          <nav class="flex gap-8">
            <button
              onclick="showTab('description')"
              class="tab-btn active pb-4 font-semibold border-b-2 transition-colors"
              data-tab="description">
              {{ 'products.description'|t }}
            </button>
            <button
              onclick="showTab('reviews')"
              class="tab-btn pb-4 font-semibold border-b-2 transition-colors"
              data-tab="reviews">
              {{ 'products.reviews'|t }} ({{ product.rating.count|default(0) }})
            </button>
          </nav>
        </div>

        {# Tab Content #}
        <div class="tab-content">
          {# Description Tab #}
          <div id="tab-description" class="tab-pane active">
            <div class="prose max-w-none text-gray-700">
              {{ product.description|raw }}
            </div>
          </div>

          {# Reviews Tab #}
          <div id="tab-reviews" class="tab-pane hidden">
            {% if store.settings.rating.show_on_product %}
              <salla-comments item-id="{{ product.id }}" type="product"></salla-comments>
            {% else %}
              <div class="text-center py-12">
                <i class="sicon-star text-gray-300 text-6xl mb-4"></i>
                <p class="text-gray-600">{{ 'products.no_reviews_yet'|t }}</p>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {# === OFFERS === #}
    <salla-offer></salla-offer>

    {# === RELATED PRODUCTS === #}
    <div class="mt-12">
      <salla-products-slider
        source="related"
        source-value="{{ product.id }}"
        block-title="{{ 'products.similar_products'|t }}"
        display-all-url>
      </salla-products-slider>
    </div>

  </div>
</div>

{% endblock %}

{% block scripts %}
<script defer src="{{ 'product.js' | asset }}"></script>
{% if product.has_3d_image %}
  <script type="module" defer src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
{% endif %}
{% if product.digital_files_settings %}
  <script type="module" defer src="{{ 'digital-files.js'|asset }}"></script>
{% endif %}

<script>
// Tabs functionality
function showTab(tabName) {
  // Hide all tab panes
  document.querySelectorAll('.tab-pane').forEach(pane => {
    pane.classList.add('hidden');
    pane.classList.remove('active');
  });

  // Show selected tab pane
  const selectedPane = document.getElementById(`tab-${tabName}`);
  if (selectedPane) {
    selectedPane.classList.remove('hidden');
    selectedPane.classList.add('active');
  }

  // Update tab buttons
  document.querySelectorAll('.tab-btn').forEach(btn => {
    if (btn.dataset.tab === tabName) {
      btn.classList.add('active', 'border-primary-600', 'text-primary-600');
      btn.classList.remove('border-transparent', 'text-gray-600');
    } else {
      btn.classList.remove('active', 'border-primary-600', 'text-primary-600');
      btn.classList.add('border-transparent', 'text-gray-600');
    }
  });
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  showTab('description');
});
</script>

<style>
.tab-btn {
  @apply border-transparent text-gray-600 hover:text-gray-900 hover:border-gray-300 cursor-pointer;
}

.tab-btn.active {
  @apply border-primary-600 text-primary-600;
}

.product-single-page .details-slider {
  max-height: 600px;
}
</style>
{% endblock %}
